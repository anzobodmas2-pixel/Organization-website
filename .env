# TRGD Website Environment Configuration
# Last Updated: April 23, 2026

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3000

# ============================================================================
# EMAIL CONFIGURATION - SMTP Settings for Contact Form Notifications
# ============================================================================
# Choose ONE configuration method below based on your email provider

# OPTION 1: Gmail with App Password (Recommended for Gmail)
# NOTE: Enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
SMTP_SERVICE=gmail
SMTP_USER=trgd2021@gmail.com
SMTP_PASS=your_gmail_app_password_here
# Gmail automatically uses port 587 with TLS

# OPTION 2: Custom SMTP Server (for enterprise email)
# Uncomment and configure if NOT using Gmail
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@yourdomain.com
# SMTP_PASS=your_email_password

# OPTION 3: SendGrid SMTP Relay
# Uncomment to use SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your_sendgrid_api_key

# Email sender address (from field)
SMTP_FROM=noreply@trgd.org

# Organization email for receiving contact submissions
ORG_EMAIL=trgd2021@gmail.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite database file location (created automatically if not exists)
DATABASE_URL=database.sqlite

# ============================================================================
# SECURITY NOTES
# ============================================================================
# - NEVER commit this file to public repositories
# - Use .gitignore to exclude .env files
# - For Gmail: Use App Passwords, NOT your main Gmail password
# - For production: Use environment variables from your hosting provider
# - Rotate credentials regularly and monitor access logs

# ============================================================================
# TESTING EMAIL CONFIGURATION
# ============================================================================
# To test email configuration:
# 1. Fill in SMTP credentials above
# 2. Run: npm start
# 3. Submit a contact form on the website
# 4. Check trgd2021@gmail.com for the notification
# 5. Check the server console for any error messages
