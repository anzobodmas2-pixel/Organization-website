# Configure SMTP credentials to send contact messages by email
# Example for Gmail with App Password
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-app-password
SMTP_FROM=trgd2021@gmail.com
ORG_EMAIL=trgd2021@gmail.com

